<IfModule mod_rewrite.c>
  RewriteEngine On

  # BLOCK SPAM URLs (410)
  RewriteCond %{REQUEST_URI} ^/20- [NC,OR]
  RewriteCond %{REQUEST_URI} (casino|bet|slot|spin|free-spins) [NC]
  RewriteRule .* - [R=410,L]

  # Force HTTPS + WWW
  RewriteCond %{HTTPS} off [OR]
  RewriteCond %{HTTP_HOST} !^www\.purvsoft\.com$ [NC]
  RewriteRule ^(.*)$ https://www.purvsoft.com/$1 [R=301,L]

  # Remove trailing slash
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^(.+)/$ /$1 [R=301,L]

  # SERVICES REDIRECTS (short → full paths)
  RewriteRule ^seo/?$ /services/seo [R=301,L]
  RewriteRule ^web-development/?$ /services/website-development [R=301,L]
  RewriteRule ^digital-marketing/?$ /services/digital-marketing [R=301,L]
  RewriteRule ^software-development/?$ /services/custom-software-development [R=301,L]
  RewriteRule ^content-management/?$ /services/content-management [R=301,L]
  RewriteRule ^mobile-app/?$ /services/mobile-app-development [R=301,L]
  RewriteRule ^ecommerce/?$ /services/e-commerce-development [R=301,L]
  RewriteRule ^reactjs/?$ /services/reactjs-development [R=301,L]
  RewriteRule ^nextjs/?$ /services/nextjs-development [R=301,L]
  RewriteRule ^angular/?$ /services/angular-development [R=301,L]
  RewriteRule ^shopify/?$ /services/shopify-development [R=301,L]
  RewriteRule ^flutter/?$ /services/flutter-development [R=301,L]
  RewriteRule ^laravel/?$ /services/laravel-development [R=301,L]
  RewriteRule ^nodejs/?$ /services/nodejs-development [R=301,L]
  RewriteRule ^youtube-marketing/?$ /services/youtube-marketing [R=301,L]
  RewriteRule ^meta-ads/?$ /services/meta-ads [R=301,L]
  RewriteRule ^google-ads/?$ /services/google-ads [R=301,L]
  RewriteRule ^ai-automation/?$ /services/ai-automation [R=301,L]
  RewriteRule ^challenges/?$ /services/our-challenges [R=301,L]

  # Allow real files/folders to be served directly
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # ✅ React SPA fallback — must be LAST, handles all React routes
  RewriteRule ^ index.html [L]

</IfModule>